{
  "name": "nomomartyria-bible-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:how-to-study": "node ../scripts/sync-how-to-study-manuscript.mjs",
    "validate:how-to-study": "node ../scripts/generate-how-to-study-mobile-sections.mjs",
    "prebuild": "npm run sync:how-to-study && npm run validate:how-to-study",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "validate:strongs": "node ../scripts/kjv/validate-strongs.mjs",
    "configure:supabase": "node ../scripts/configure-supabase-env.mjs",
    "verify:supabase": "node scripts/verify-supabase-auth.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "dompurify": "^3.4.11",
    "lucide-react": "^1.23.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.0"
  }
